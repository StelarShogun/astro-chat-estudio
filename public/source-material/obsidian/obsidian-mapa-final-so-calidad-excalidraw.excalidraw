			"link": null,
			"locked": false,
			"index": "a008",
			"text": "Calidad usa la memoria como locker: cada proceso\ntiene un bloque para sus datos. Cuando E/S termina,\ncopia el dato verificado al bloque correspondiente y\navisa al planificador.",
			"fontSize": 25,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Calidad usa la memoria como locker: cada proceso tiene un bloque para sus datos. Cuando E/S termina, copia el dato verificado al bloque correspondiente y avisa al planificador.",
			"lineHeight": 1.25,
			"baseline": 22,
			"autoResize": false,
			"hasTextLink": false,
			"rawText": ""
		},
