			"baseline": 45,
			"autoResize": false,
			"hasTextLink": false,
			"rawText": ""
		},
		{
			"id": "PKaMppex",
			"type": "text",
			"x": 272,
			"y": -470,
			"width": 2256,
			"height": 35,
			"angle": 0,
			"strokeColor": "#334155",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 1,
			"strokeStyle": "solid",
