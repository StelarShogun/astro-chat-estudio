		{
			"id": "E5u6OsPN",
			"type": "text",
			"x": -5128,
			"y": -2470,
			"width": 2256,
			"height": 70,
			"angle": 0,
			"strokeColor": "#334155",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 1,
			"strokeStyle": "solid",
			"roughness": 1,
			"opacity": 100,
			"groupIds": [],
			"frameId": "frame_00001",
			"roundness": null,
			"seed": 100451,
			"version": 2,
			"versionNonce": 1906840098,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1781330001600,
			"link": null,
			"locked": false,
			"index": "a001",
			"text": "La nota buena no empieza con una definicion. Empieza leyendo que dato entra, que recurso presiona, que cola se satura, que politica conviene y que costo\naparece si se decide mal.",
			"fontSize": 28,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "La nota buena no empieza con una definicion. Empieza leyendo que dato entra, que recurso presiona, que cola se satura, que politica conviene y que costo aparece si se decide mal.",
			"lineHeight": 1.25,
			"baseline": 24,
			"autoResize": false,
			"hasTextLink": false,
			"rawText": ""
		},
