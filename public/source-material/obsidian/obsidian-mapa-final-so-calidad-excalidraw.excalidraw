			"boundElements": [],
			"updated": 1781330001520,
			"link": null,
			"locked": false,
			"index": "a0251",
			"text": "Proceso -> recurso significa solicitud.\nRecurso -> proceso significa asignacion.\nCon una instancia por recurso, ciclo implica\ninterbloqueo. Con varias instancias, hay que\nanalizar mas.",
			"fontSize": 25,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Proceso -> recurso significa solicitud.\nRecurso -> proceso significa asignacion.\nCon una instancia por recurso, ciclo implica interbloqueo. Con varias instancias, hay que analizar mas.",
			"lineHeight": 1.25,
			"baseline": 22,
			"autoResize": false,
			"hasTextLink": false,
			"rawText": ""
		},
