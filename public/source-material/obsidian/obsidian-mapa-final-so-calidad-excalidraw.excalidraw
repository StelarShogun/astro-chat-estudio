		{
			"id": "coSx70rB",
			"type": "text",
			"x": -1629,
			"y": -2255,
			"width": 648,
			"height": 156.25,
			"angle": 0,
			"strokeColor": "#111827",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 1,
			"strokeStyle": "solid",
			"roughness": 1,
			"opacity": 100,
			"groupIds": [],
			"frameId": "frame_00002",
			"roundness": null,
			"seed": 101722,
			"version": 1,
			"versionNonce": 202814,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1781330001520,
			"link": null,
			"locked": false,
			"index": "a0041",
			"text": "La rafaga muestra cuanto aprovecha CPU antes\nde esperar E/S o ser expulsado. Si la rafaga es\ncorta y conocida, SJF puede reducir espera. Si es\nlarga, puede monopolizar. Si hay usuario interactivo,\nRR reparte respuesta.",
			"fontSize": 25,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "La rafaga muestra cuanto aprovecha CPU antes de esperar E/S o ser expulsado. Si la rafaga es corta y conocida, SJF puede reducir espera. Si es larga, puede monopolizar. Si hay usuario interactivo, RR reparte respuesta.",
			"lineHeight": 1.25,
			"baseline": 22,
			"autoResize": false,
			"hasTextLink": false,
			"rawText": ""
		},
