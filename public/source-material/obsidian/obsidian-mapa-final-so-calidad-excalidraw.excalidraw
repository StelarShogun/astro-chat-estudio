			"link": null,
			"locked": false,
			"index": "a0435",
			"text": "Imagen: memoria alta, E/S al cargar, CPU\nalta al procesar regiones.\nAudio: flujo continuo, buffer obligatorio.\nCache solo si se reusan filtros, segmentos o\npatrones.",
			"fontSize": 26,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Imagen: memoria alta, E/S al cargar, CPU alta al procesar regiones.\nAudio: flujo continuo, buffer obligatorio.\nCache solo si se reusan filtros, segmentos o patrones.",
			"lineHeight": 1.25,
			"baseline": 22,
			"autoResize": false,
			"hasTextLink": false,
			"rawText": ""
