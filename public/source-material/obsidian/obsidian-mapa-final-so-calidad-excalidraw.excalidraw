			"link": null,
			"locked": false,
			"index": "a0153",
			"text": "Si no cabe todo, se trabaja con paginas y marcos. Un fallo de\npagina trae desde disco lo que falta. Si el sistema pasa mas\ntiempo trayendo/sacando paginas que ejecutando, hay thrashing.",
			"fontSize": 24,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Si no cabe todo, se trabaja con paginas y marcos. Un fallo de pagina trae desde disco lo que falta. Si el sistema pasa mas tiempo trayendo/sacando paginas que ejecutando, hay thrashing.",
			"lineHeight": 1.25,
			"baseline": 21,
			"autoResize": false,
			"hasTextLink": false,
			"rawText": ""
		},
