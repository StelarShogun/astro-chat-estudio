			"boundElements": [],
			"updated": 1781330001520,
			"link": null,
			"locked": false,
			"index": "a0432",
			"text": "Dato numerico periodico.\nE/S alta, CPU baja/media.\nBuffer si produce mientras consumo.\nTiempo real solo si hay alarma o control\ninmediato.\nArchivo: registros con timestamp.",
			"fontSize": 26,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Dato numerico periodico.\nE/S alta, CPU baja/media.\nBuffer si produce mientras consumo.\nTiempo real solo si hay alarma o control inmediato.\nArchivo: registros con timestamp.",
