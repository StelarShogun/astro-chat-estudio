		},
		{
			"id": "U0qOLkBb",
			"type": "text",
			"x": -3954,
			"y": -2250,
			"width": 1008,
			"height": 125,
			"angle": 0,
			"strokeColor": "#111827",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 1,
			"strokeStyle": "solid",
			"roughness": 1,
			"opacity": 100,
			"groupIds": [],
			"frameId": "frame_00001",
			"roundness": null,
			"seed": 100697,
			"version": 1,
			"versionNonce": 201139,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1781330001520,
			"link": null,
			"locked": false,
			"index": "a0016",
			"text": "No analice el dato ya interpretado. Si el proceso usa una imagen, primero hay\npixeles/bloques; si usa audio, primero hay muestras; si usa sensor, primero hay\nmediciones periodicas; si usa red, primero hay paquetes que pueden llegar con\nerror o retraso.",
			"fontSize": 25,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "No analice el dato ya interpretado. Si el proceso usa una imagen, primero hay pixeles/bloques; si usa audio, primero hay muestras; si usa sensor, primero hay mediciones periodicas; si usa red, primero hay paquetes que pueden llegar con error o retraso.",
			"lineHeight": 1.25,
			"baseline": 22,
			"autoResize": false,
			"hasTextLink": false,
			"rawText": ""
		},
