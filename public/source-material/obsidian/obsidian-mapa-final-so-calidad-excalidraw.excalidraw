			"boundElements": [],
			"updated": 1781330001600,
			"link": null,
			"locked": false,
			"index": "a037",
			"text": "Vale la pena distribuir?\nSi el problema necesita velocidad, tolerancia, cercania\na datos o colaboracion, puede tener sentido. Si la\nred agrega mas costo que beneficio, no.",
			"fontSize": 25,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Vale la pena distribuir?\nSi el problema necesita velocidad, tolerancia, cercania a datos o colaboracion, puede tener sentido. Si la red agrega mas costo que beneficio, no.",
			"lineHeight": 1.25,
			"baseline": 22,
			"autoResize": false,
			"hasTextLink": false,
			"rawText": ""
		},
