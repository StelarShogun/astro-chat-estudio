			"boundElements": [],
			"updated": 1781330001520,
			"link": null,
			"locked": false,
			"index": "a0193",
			"text": "Sensor medico: archivo regular de registros con\ntimestamp y valor.\nAudio: stream o binario temporal.\nImagen: binario por bloques o acceso directo por\nregiones.\nBD: coleccion de archivos con acceso indexado.",
			"fontSize": 25,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Sensor medico: archivo regular de registros con timestamp y valor.\nAudio: stream o binario temporal.\nImagen: binario por bloques o acceso directo por regiones.\nBD: coleccion de archivos con acceso indexado.",
			"lineHeight": 1.25,
			"baseline": 22,
			"autoResize": false,
			"hasTextLink": false,
			"rawText": ""
		},
