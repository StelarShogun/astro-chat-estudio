			"link": null,
			"locked": false,
			"index": "a0373",
			"text": "Fuerte: parece un unico CPU/memoria; alta\ncoordinacion, hardware parecido, red rapida.\nDebil: hosts autonomos por red; mas flexible, pero\nlatencia y fallos pesan.",
			"fontSize": 25,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Fuerte: parece un unico CPU/memoria; alta coordinacion, hardware parecido, red rapida.\nDebil: hosts autonomos por red; mas flexible, pero latencia y fallos pesan.",
			"lineHeight": 1.25,
			"baseline": 22,
			"autoResize": false,
			"hasTextLink": false,
			"rawText": ""
		},
