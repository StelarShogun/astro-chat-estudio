			"boundElements": [],
			"updated": 1781330001520,
			"link": null,
			"locked": false,
			"index": "a0198",
			"text": "Dispositivo fisico: produce o consume senales.\nControlador: electronica que expone registros.\nDriver: software del SO que habla con el controlador.\nSoftware independiente: cola, nombres, permisos,\nabstracciones.\nProceso: pide leer/escribir.",
			"fontSize": 25,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Dispositivo fisico: produce o consume senales.\nControlador: electronica que expone registros.\nDriver: software del SO que habla con el controlador.\nSoftware independiente: cola, nombres, permisos, abstracciones.\nProceso: pide leer/escribir.",
			"lineHeight": 1.25,
			"baseline": 22,
			"autoResize": false,
			"hasTextLink": false,
			"rawText": ""
		},
