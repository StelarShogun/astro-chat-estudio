			"boundElements": [],
			"updated": 1781330001520,
			"link": null,
			"locked": false,
			"index": "a0254",
			"text": "E = recursos existentes.\nA = disponibles.\nC = asignacion actual.\nR = solicitudes restantes.\nSi R_i <= A, el proceso puede terminar y liberar\nC_i. Si nadie cumple, hay bloqueo.",
			"fontSize": 25,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "E = recursos existentes.\nA = disponibles.\nC = asignacion actual.\nR = solicitudes restantes.\nSi R_i <= A, el proceso puede terminar y liberar C_i. Si nadie cumple, hay bloqueo.",
			"lineHeight": 1.25,
			"baseline": 22,
			"autoResize": false,
			"hasTextLink": false,
			"rawText": ""
		},
