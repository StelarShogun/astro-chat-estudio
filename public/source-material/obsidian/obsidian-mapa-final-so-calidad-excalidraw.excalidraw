			"boundElements": [],
			"updated": 1781330001520,
			"link": null,
			"locked": false,
			"index": "a0201",
			"text": "Temporalidad. Se usa cuando el productor\nentrega datos antes de que el consumidor pueda\nprocesarlos: sensor, audio, red, disco o impresora.\nRiesgo: desbordamiento y perdida.",
			"fontSize": 25,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Temporalidad. Se usa cuando el productor entrega datos antes de que el consumidor pueda procesarlos: sensor, audio, red, disco o impresora. Riesgo: desbordamiento y perdida.",
			"lineHeight": 1.25,
			"baseline": 22,
			"autoResize": false,
			"hasTextLink": false,
			"rawText": ""
		},
		{
			"id": "rectangle_00202",
			"type": "rectangle",
