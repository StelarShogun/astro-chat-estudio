			"index": "a0421",
			"text": "SISD: una instruccion, un dato.\nSIMD: una instruccion, muchos datos.\nMIMD: muchas instrucciones, muchos datos. Es el modelo mas\nnatural para sistemas distribuidos generales.",
			"fontSize": 25,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "SISD: una instruccion, un dato.\nSIMD: una instruccion, muchos datos.\nMIMD: muchas instrucciones, muchos datos. Es el modelo mas natural para sistemas distribuidos generales.",
			"lineHeight": 1.25,
			"baseline": 22,
			"autoResize": false,
			"hasTextLink": false,
			"rawText": ""
		},
