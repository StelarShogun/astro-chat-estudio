			"link": null,
			"locked": false,
			"index": "a0083",
			"text": "Representa unidades libres/ocupadas con 0/1. Es\nsimple, pero encontrar espacio requiere buscar una\ncorrida suficientemente larga. Si hay huecos\ndispersos, aparece fragmentacion externa.",
			"fontSize": 25,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Representa unidades libres/ocupadas con 0/1. Es simple, pero encontrar espacio requiere buscar una corrida suficientemente larga. Si hay huecos dispersos, aparece fragmentacion externa.",
			"lineHeight": 1.25,
			"baseline": 22,
			"autoResize": false,
			"hasTextLink": false,
			"rawText": ""
