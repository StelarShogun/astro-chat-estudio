			"version": 1,
			"versionNonce": 224522,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1781330001520,
			"link": null,
			"locked": false,
			"index": "a0365",
			"text": "No pregunta si ahora mismo alcanza para uno: pregunta si al conceder\nrecursos el sistema queda en estado seguro. Estado seguro significa que\nexiste una secuencia donde todos terminan. Estado inseguro no es bloqueo\ninmediato, pero puede terminar en bloqueo.",
			"fontSize": 25,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "No pregunta si ahora mismo alcanza para uno: pregunta si al conceder recursos el sistema queda en estado seguro. Estado seguro significa que existe una secuencia donde todos terminan. Estado inseguro no es bloqueo inmediato, pero puede terminar en bloqueo.",
			"lineHeight": 1.25,
			"baseline": 22,
			"autoResize": false,
			"hasTextLink": false,
			"rawText": ""
		},
		{
			"id": "O4pgWWXv",
			"type": "text",
			"x": 270,
			"y": -545,
			"width": 2260,
			"height": 65,
			"angle": 0,
			"strokeColor": "#7c3aed",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 1,
			"strokeStyle": "solid",
			"roughness": 1,
			"opacity": 100,
