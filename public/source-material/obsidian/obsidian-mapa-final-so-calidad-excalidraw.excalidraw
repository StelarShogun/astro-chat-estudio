		{
			"id": "dMLu4Byq",
			"type": "text",
			"x": -2394,
			"y": 620,
			"width": 958,
			"height": 125,
			"angle": 0,
			"strokeColor": "#111827",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 1,
			"strokeStyle": "solid",
			"roughness": 1,
			"opacity": 100,
			"groupIds": [],
			"frameId": "frame_00006",
