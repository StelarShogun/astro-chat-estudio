			"link": null,
			"locked": false,
			"index": "a019",
			"text": "Un nodo-i guarda metadatos y punteros a\nbloques. Sirve para explicar que un archivo no es\n'una cosa continua bonita': el SO traduce nombre,\npermisos y bloques fisicos.",
			"fontSize": 25,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Un nodo-i guarda metadatos y punteros a bloques. Sirve para explicar que un archivo no es 'una cosa continua bonita': el SO traduce nombre, permisos y bloques fisicos.",
			"lineHeight": 1.25,
			"baseline": 22,
			"autoResize": false,
			"hasTextLink": false,
			"rawText": ""
		},
