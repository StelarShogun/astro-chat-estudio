			"link": null,
			"locked": false,
			"index": "a0243",
			"text": "No decir 'cache porque hay muchos datos'. Muchos datos\nnuevos piden buffer. Cache solo si se vuelven a\nconsultar.",
			"fontSize": 26,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "No decir 'cache porque hay muchos datos'. Muchos datos nuevos piden buffer. Cache solo si se vuelven a consultar.",
