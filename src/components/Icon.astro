---
import { icons } from '../lib/icons.js';
const { name, size = 18, class: className = '' } = Astro.props;
const body = icons[name] || '';
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  class={`icon ${className}`}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={body}
/>
