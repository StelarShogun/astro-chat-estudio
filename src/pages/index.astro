---
import Layout from '../layouts/Layout.astro';
import QuickGuide from '../components/QuickGuide.astro';
import Questions from '../components/Questions.astro';
import Exams from '../components/Exams.astro';
import Theory from '../components/Theory.astro';
import MediCore from '../components/MediCore.astro';
import Lecheria from '../components/Lecheria.astro';
import Tanenbaum from '../components/Tanenbaum.astro';
import DocumentReader from '../components/DocumentReader.jsx';
import CaseSolver from '../components/CaseSolver.jsx';
import CaseViewer from '../components/CaseViewer.jsx';
import Icon from '../components/Icon.astro';

const sections = [
  { id: 'inicio', label: 'Método', icon: 'metodo', hint: 'Cómo razonar el examen' },
  { id: 'resolver', label: 'Resolver caso', icon: 'resolver', hint: 'Plantilla en blanco' },
  { id: 'casos', label: 'Examen interactivo', icon: 'examen', hint: 'Practica y recibe feedback' },
  { id: 'transcripciones', label: 'Transcripciones', icon: 'transcripcion', hint: 'Clases en texto' },
  { id: 'obsidian', label: 'Notas', icon: 'notas', hint: 'Notas del curso' },
  { id: 'preguntas', label: 'Preguntas', icon: 'preguntas', hint: 'Banco de preguntas' },
  { id: 'examenes', label: 'Exámenes', icon: 'examenes', hint: 'Fotos de los exámenes' },
  { id: 'medicore', label: 'Caso MediCore', icon: 'medicore', hint: 'Examen 2 resuelto' },
  { id: 'lecheria', label: 'Caso Lechería', icon: 'examen', hint: 'Examen 1 resuelto' },
  { id: 'teoria', label: 'Teoría guía', icon: 'teoria', hint: 'Resumen por tema' },
  { id: 'tanenbaum', label: 'Tanenbaum', icon: 'libro', hint: 'Libro por capítulo' },
];
---

<Layout>
  <main class="app-shell sidebar-open" id="app-shell">
    <aside class="sidebar" aria-label="Dashboard de estudio">
      <div class="sidebar-top">
        <button
          class="collapse-button"
          type="button"
          id="collapse-button"
          aria-label="Contraer dashboard"
          aria-expanded="true"
        >
          <span class="when-open"><Icon name="contraer" size={20} /></span>
          <span class="when-collapsed"><Icon name="expandir" size={20} /></span>
        </button>
        <div class="brand-block">
          <span>Sistemas Operativos</span>
          <strong>Calidad OS</strong>
          <p>Transcripciones, notas y exámenes para repasar con respuesta de examen.</p>
        </div>
      </div>

      <nav class="section-nav" aria-label="Secciones principales">
        {sections.map((section, index) => (
          <button
            type="button"
            class={index === 0 ? 'active' : ''}
            data-target={section.id}
            aria-current={index === 0 ? 'page' : undefined}
            title={`${section.label} — ${section.hint}`}
          >
            <span class="nav-icon"><Icon name={section.icon} size={20} /></span>
            <span class="nav-text">
              <strong>{section.label}</strong>
              <small>{section.hint}</small>
            </span>
            <span class="nav-key">{index < 9 ? index + 1 : index === 9 ? '0' : ''}</span>
          </button>
        ))}
      </nav>

      <p class="sidebar-hint">Atajos: teclas 1–9 y 0 cambian de sección.</p>
    </aside>

    <section class="content">
      <header class="hero-panel">
        <div>
          <p class="eyebrow">Curso de Sistemas Operativos</p>
          <h1>Todo el material para estudiar como examen.</h1>
          <p class="hero-text">
            Repasa con las transcripciones completas, las notas del curso, mapas visuales y
            exámenes reales. Caracteriza casos en la plantilla y consulta a Tanenbaum como apoyo.
          </p>
        </div>
        <div class="source-panel">
          <span>Ruta de estudio</span>
          <strong>Caracterizar, decidir y defender</strong>
          <p>Primero se separan procesos, dispositivos, archivos y recursos.</p>
          <p>Después se elige la política y se justifica con lenguaje de examen.</p>
          <p>Al final se practica con casos completos y preguntas reales.</p>
        </div>
      </header>

      <div class="section-panel is-active" data-section="inicio">
        <QuickGuide />
      </div>
      <div class="section-panel" data-section="resolver">
        <CaseSolver client:visible />
      </div>
      <div class="section-panel" data-section="casos">
        <CaseViewer client:visible />
      </div>
      <div class="section-panel" data-section="transcripciones">
        <DocumentReader section="transcripciones" client:visible />
      </div>
      <div class="section-panel" data-section="obsidian">
        <DocumentReader section="obsidian" client:visible />
      </div>
      <div class="section-panel" data-section="preguntas">
        <Questions />
      </div>
      <div class="section-panel" data-section="examenes">
        <Exams />
      </div>
      <div class="section-panel" data-section="medicore">
        <MediCore />
      </div>
      <div class="section-panel" data-section="lecheria">
        <Lecheria />
      </div>
      <div class="section-panel" data-section="teoria">
        <Theory />
      </div>
      <div class="section-panel" data-section="tanenbaum">
        <Tanenbaum />
      </div>
    </section>
  </main>
</Layout>

<script>
  const STORAGE_SECTION = 'calidad-os-section';
  const STORAGE_SIDEBAR = 'calidad-os-sidebar-collapsed';
  const shell = document.getElementById('app-shell');
  const navButtons = Array.from(document.querySelectorAll('.section-nav button[data-target]'));
  const panels = Array.from(document.querySelectorAll('.section-panel'));
  const collapseButton = document.getElementById('collapse-button');

  const activate = (target) => {
    let matched = false;
    navButtons.forEach((button) => {
      const isActive = button.getAttribute('data-target') === target;
      if (isActive) matched = true;
      button.classList.toggle('active', isActive);
      if (isActive) button.setAttribute('aria-current', 'page');
      else button.removeAttribute('aria-current');
    });
    if (!matched) return;
    panels.forEach((panel) => {
      panel.classList.toggle('is-active', panel.getAttribute('data-section') === target);
    });
    try {
      localStorage.setItem(STORAGE_SECTION, target);
    } catch {}
  };

  navButtons.forEach((button) => {
    button.addEventListener('click', () => activate(button.getAttribute('data-target')));
  });

  // Atajos de teclado: 1–9 van a las primeras nueve secciones y 0 a la décima.
  // Se ignora cuando se escribe en un campo.
  document.addEventListener('keydown', (event) => {
    if (event.metaKey || event.ctrlKey || event.altKey) return;
    const tag = document.activeElement?.tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA') return;
    if (!/^[0-9]$/.test(event.key)) return;
    const index = event.key === '0' ? 9 : Number(event.key) - 1;
    if (index >= 0 && index < navButtons.length) {
      activate(navButtons[index].getAttribute('data-target'));
    }
  });

  const setCollapsed = (collapsed) => {
    shell.classList.toggle('sidebar-collapsed', collapsed);
    shell.classList.toggle('sidebar-open', !collapsed);
    collapseButton.setAttribute('aria-expanded', String(!collapsed));
    collapseButton.setAttribute('aria-label', collapsed ? 'Abrir dashboard' : 'Contraer dashboard');
    try {
      localStorage.setItem(STORAGE_SIDEBAR, String(collapsed));
    } catch {}
  };

  collapseButton?.addEventListener('click', () => {
    setCollapsed(!shell.classList.contains('sidebar-collapsed'));
  });

  // Restaurar estado previo.
  try {
    const savedSection = localStorage.getItem(STORAGE_SECTION);
    if (savedSection) activate(savedSection);
    if (localStorage.getItem(STORAGE_SIDEBAR) === 'true') setCollapsed(true);
  } catch {}
</script>
